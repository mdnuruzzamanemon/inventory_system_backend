# Server
NODE_ENV=development
PORT=4000

# Database — use DATABASE_URL (Neon/Railway) OR individual params
DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=inventory_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Reservation
RESERVATION_TTL_SECONDS=60
