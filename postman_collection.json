{
  "info": {
    "name": "Inventory System API",
    "description": "Limited Edition Sneaker Drop - Inventory System\n\nBase URL: http://localhost:4000/api\n\nAuth flow:\n1. Register a user\n2. Login to get JWT token\n3. Use the token in protected routes\n\nNote: Drops (Create & Get Active) are public routes — no token needed.\nReservations and Purchases require authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success) {",
                  "  pm.collectionVariables.set('token', jsonData.data.token);",
                  "  pm.collectionVariables.set('userId', jsonData.data.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success) {",
                  "  pm.collectionVariables.set('token', jsonData.data.token);",
                  "  pm.collectionVariables.set('userId', jsonData.data.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Drops",
      "item": [
        {
          "name": "Create Drop",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Air Jordan 1 Retro High\",\n  \"description\": \"Limited edition sneaker drop\",\n  \"startTime\": \"2026-07-10T00:00:00.000Z\",\n  \"products\": [\n    {\n      \"name\": \"Air Jordan 1 - Chicago\",\n      \"price\": 189.99,\n      \"stock\": 100\n    },\n    {\n      \"name\": \"Air Jordan 1 - Bred\",\n      \"price\": 199.99,\n      \"stock\": 75\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/drops",
              "host": ["{{baseUrl}}"],
              "path": ["drops"]
            }
          }
        },
        {
          "name": "Get Active Drops",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/drops/active",
              "host": ["{{baseUrl}}"],
              "path": ["drops", "active"]
            }
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Reserve Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"REPLACE_WITH_PRODUCT_UUID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["reservations"]
            }
          }
        },
        {
          "name": "Get My Reservations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations/me",
              "host": ["{{baseUrl}}"],
              "path": ["reservations", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Purchases",
      "item": [
        {
          "name": "Complete Purchase",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservationId\": \"REPLACE_WITH_RESERVATION_UUID\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/purchases",
              "host": ["{{baseUrl}}"],
              "path": ["purchases"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ]
}
